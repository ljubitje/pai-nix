+#!/usr/bin/env bun
+/**
+ * WritePaiState.ts — SessionStart producer for the statusline STATE meter.
+ *
+ * Reads:  ~/.claude/PAI/USER/TELOS/PAI_STATE_INPUT.yaml
+ *           dimensions: { health, creative, freedom, relationships, money }
+ *           values: 0-100 (percent toward ideal) or null (not rated).
+ * Writes: ~/.claude/PAI/USER/TELOS/PAI_STATE.json
+ *           in the schema statusline-command.sh:1188-1196 expects.
+ *
+ * Deterministic. ~10ms. Silent on missing/malformed input — the
+ * statusline already falls back to "N/A" when PAI_STATE.json is
+ * absent or contains nulls.
+ *
+ * Closes #1132. Separates producer (this file) from analytics
+ * (ComputeGap.ts). The statusline contract is unchanged.
+ */
+
+import { readFileSync, writeFileSync, existsSync } from "fs";
+import { join } from "path";
+import { parse as parseYaml } from "yaml";
+
+const PAI_DIR = process.env.PAI_DIR || join(process.env.HOME || "", ".claude/PAI");
+const INPUT_PATH = join(PAI_DIR, "USER/TELOS/PAI_STATE_INPUT.yaml");
+const OUTPUT_PATH = join(PAI_DIR, "USER/TELOS/PAI_STATE.json");
+
+const DIMENSIONS = ["health", "creative", "freedom", "relationships", "money"] as const;
+type Dimension = typeof DIMENSIONS[number];
+
+interface Input {
+  dimensions?: Partial<Record<Dimension, number | null>>;
+}
+
+function clampPct(value: unknown): number | null {
+  if (typeof value !== "number") return null;
+  if (!Number.isFinite(value)) return null;
+  if (value < 0 || value > 100) return null;
+  return value;
+}
+
+function main(): void {
+  if (!existsSync(INPUT_PATH)) return;
+
+  let parsed: Input;
+  try {
+    parsed = (parseYaml(readFileSync(INPUT_PATH, "utf-8")) as Input) ?? {};
+  } catch {
+    return;
+  }
+
+  const dims: Record<Dimension, { pct: number | null }> = {} as Record<Dimension, { pct: number | null }>;
+  for (const key of DIMENSIONS) {
+    dims[key] = { pct: clampPct(parsed?.dimensions?.[key]) };
+  }
+
+  const output = { dimensions: dims, updatedAt: new Date().toISOString() };
+  writeFileSync(OUTPUT_PATH, JSON.stringify(output, null, 2));
+}
+
+main();
--- a/Releases/v5.0.0/.claude/PAI/statusline-command.sh
+++ b/Releases/v5.0.0/.claude/PAI/statusline-command.sh
