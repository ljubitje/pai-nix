-    .filter(Boolean) as { id: string, text: string }[]
+  const out: { id: string, text: string }[] = []
+  for (const line of content.split("\n")) {
+    // Bullet form: "- **G0**: text" or "- G0: text"
+    if (/^[-*]\s*\*{0,2}G\d+\*{0,2}:/.test(line)) {
+      const m = line.match(/\*{0,2}(G\d+)\*{0,2}:\s*(.+)/)
+      if (m) out.push({ id: m[1], text: m[2].trim() })
+      continue
+    }
+    // Header form (canonical PAI source files after /interview): "## G0: text",
+    // "### G0: text". Strip a trailing "(parenthetical)" if present.
+    const header = line.match(/^#{2,4}\s+(G\d+):\s*(.+?)(?:\s*\(.*\))?\s*$/)
+    if (header) out.push({ id: header[1], text: header[2].trim() })
+  }
+  return out
 }
 
